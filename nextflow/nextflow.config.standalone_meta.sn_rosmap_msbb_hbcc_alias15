/*
 * Standalone meta-analysis for sn cohorts with alias-harmonized cell types:
 *   - sn_ROSMAP
 *   - MSBB_sn
 *   - sn_NIMH_HBCC
 *
 * Harmonized labels are staged in results/meta_sn_alias15_inputs.
 * Strict mode: require presence in all three cohorts (min_present_cohorts = 3).
 */

includeConfig 'nextflow.config.standalone_meta'

params {
    base_dir = "${projectDir}"
    meta_input_results_dir = "${projectDir}/results/meta_sn_alias15_inputs"

    cohorts = ["ROSMAP", "MSBB", "NIMH_HBCC"]
    cohort_include = ["ROSMAP", "MSBB", "NIMH_HBCC"]

    min_present_cohorts = 3

    output_dir = "${projectDir}/results/meta_analysis_sn_rosmap_msbb_hbcc_alias15"
    harmonized_output_dir = "${output_dir}/harmonized"
    audit_output_dir = "${output_dir}/audit"
    heterogeneity_output_dir = "${output_dir}/heterogeneity"

    // Plotting will be submitted separately via SLURM.
    run_plot_meta = false
}
