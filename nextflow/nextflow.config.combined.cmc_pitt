/*
 * Combined Pipeline Configuration for CMC_PITT Cohort
 * 
 * This configuration runs all three workflows in sequence:
 * 1. GENOTYPING_QC_PIPELINE: QC genotyping data
 * 2. PHENOTYPE_PIPELINE: Process expression data
 * 3. GWAS_PIPELINE: Perform GWAS analysis
 */

// Include base combined configuration
includeConfig 'nextflow.config.combined'

params {
    // ============================================================================
    // GENERAL PARAMETERS
    // ============================================================================
    
    cohorts = ["CMC_PITT"]
    study = "CMC_PITT"
    
    // ============================================================================
    // PHENOTYPE PIPELINE PARAMETERS
    // ============================================================================
    
    // Input files
    count_matrix_file = '/nethome/kcni/xzhou/GWAS_tut/CMC_reimputed/CMC_PITT_count_matrix.csv'
    metadata_file = '/nethome/kcni/xzhou/GWAS_tut/CMC_reimputed/CMC_PITT_metadata.csv'
    
    // WGS files - these will be generated by GENOTYPING_QC_PIPELINE
    wgs_psam_file = "${projectDir}/results/CMC_PITT/CMC_PITT.QC.final.psam"
    pca_file = "${projectDir}/results/CMC_PITT/pca.csv"
    
    // Optional files
    biospecimen_file = '/external/rprshnas01/netdata_kcni/stlab/CMC_genotypes/SNPs/Release3/Metadata/CMC_Human_SNP_metadata.csv'
    
    // Processing parameters
    tissue_filter = "dorsolateral prefrontal cortex"
    col_sample_id_for_matching = "individualID"
    top_n_tech_cov = 20
    
    // Cell type deconvolution
    deconv_tool = "MGP"
    reference_taxonomy = "sonny_markers"
    marker_file = "/external/rprshnas01/netdata_kcni/stlab/Xiaolin/metabrain_PCA/data/new_MTGnCgG_lfct2.5_Publication.csv"
    hgnc_mapping_file = "/external/rprshnas01/kcni/dkiss/cell_prop_psychiatry/data/hgnc_complete_set.txt"
    
    // Phenotype/covariate preparation
    // Use biospec_specimen so phenotype IDs match the VCF sample IDs in the imputed pgen.
    // CMC PITT VCF sample names are "0_PITT_10005" or "0_Pitt_BP_10004" etc.; biospecimen
    // maps CMC_PITT_002 -> PITT_10005 and CMC_PITT_124 -> Pitt_BP_10004, so prepending
    // "0_" yields the correct genotype ID for both formats (138/138 VCF samples covered).
    fid_method = "biospec_specimen"
    fid_format = "0_"
    col_msex = "reportedGender"
    col_diagnosis = "primaryDiagnosis"  // used for removeBatchEffect design=
    biospec_col_individual = "Individual_ID"
    biospec_col_specimen = "Genotyping_Sample_ID"
    
    // ============================================================================
    // GENOTYPING QC PIPELINE PARAMETERS
    // ============================================================================
    
    // Input VCF files
    vcf_dir = ""  // Not used - using vcf_pattern instead
    vcf_pattern = '/external/rprshnas01/netdata_kcni/stlab/Xiaolin/CMC_imputation/imputed_chr_normalized/CMC.QC.{chrom}.normalized.vcf.gz'
    normalized_vcf_dir = "/external/rprshnas01/netdata_kcni/stlab/Xiaolin/WGS/QC/CMC_PITT_reimputed/imputed_chr_normalized"
    
    // Software paths
    plink_path = "/external/rprshnas01/kcni/mwainberg/software/plink2"
    bcftools_path = "/nethome/kcni/xzhou/.anaconda3/envs/bcftools_env/bin/bcftools"
    
    // QC parameters (matching ROSMAP, Mayo, MSBB, CMC_MSSM, CMC_PENN)
    qc_version = 'v2'  // Increment this when QC parameters change to force re-run
    maf_threshold = 0.05
    hwe_threshold = 1e-15  // Updated to match ROSMAP, Mayo, MSBB
    geno_threshold = 0.1
    mind_threshold = 0.1
    
    // VCF filtering
    vcf_min_gq = ""
    vcf_min_dp = ""
    vcf_min_qual = ""
    mach_r2_filter = 0.8  // Imputation quality filter
    
    // LD pruning (matching ROSMAP, Mayo, MSBB: --indep-pairwise 500kb 1 0.2)
    prune_window_size = 500  // Updated to match ROSMAP, Mayo, MSBB 
    prune_step_size = 1      // Updated to match ROSMAP, Mayo, MSBB 
    prune_r2_threshold = 0.2
    
    // Processing options
    normalize_vcf = false  // Already normalized
    include_x = false
    sort_vars = true
    autosome_only = true
    samples_to_keep = ""  // VCF already subsetted for PITT samples
    
    // Directories
    work_dir = "${projectDir}/work/CMC_PITT"
    log_dir = "${projectDir}/logs/CMC_PITT"
    output_dir = "${projectDir}/results/CMC_PITT"
    
    // SLURM
    use_slurm = false
    slurm_time = "24:00:00"
    
    // ============================================================================
    // GWAS PIPELINE PARAMETERS
    // ============================================================================
    
    // Software paths
    regenie_path = "/external/rprshnas01/kcni/mwainberg/software/regenie"
    metal_path = "/external/rprshnas01/netdata_kcni/stlab/Xiaolin/WGS/METAL/generic-metal/executables"
    
    // Regenie parameters
    regenie_threads = 12
    regenie_bsize = 1000
    
    // ============================================================================
    // COHORT-SPECIFIC CONFIGURATIONS
    // ============================================================================
    
    cohort_configs = [
        "CMC_PITT": [
            pgen_file: "${projectDir}/results/CMC_PITT/CMC_PITT.QC.final",
            prune_in_file: "${projectDir}/results/CMC_PITT/CMC_PITT.QC.prune.in",
            pheno_file: "${projectDir}/results/CMC_PITT/phenotypes_RINT.txt",
            covar_file: "${projectDir}/results/CMC_PITT/covariates.txt"
        ]
    ]
}

