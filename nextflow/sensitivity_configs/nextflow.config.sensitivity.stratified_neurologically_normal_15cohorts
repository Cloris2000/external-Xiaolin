/*
 * Stratified meta-analysis: neurologically normal / control brain cohorts (15-cohort base).
 *
 * Cohorts: GTEx_v10, NABEC
 * Purpose: Reference meta in controls — are cell-type signals disease-specific?
 *
 * Run: sbatch run_stratified_meta_neurologically_normal.sbatch
 */
includeConfig '../nextflow.config.standalone_meta_15cohorts'

params {
    stratified_meta_label = "neurologically_normal"
    stratified_meta_dimension = "diagnosis_group"

    cohorts = ["GTEx_v10", "NABEC"]
    cohort_include = ["GTEx_v10", "NABEC"]

    output_dir = "${projectDir}/results/meta_sensitivity/stratified_neurologically_normal_15cohorts"
    harmonized_output_dir = "${params.output_dir}/harmonized"
    audit_output_dir = "${params.output_dir}/audit"
    heterogeneity_output_dir = "${params.output_dir}/heterogeneity"

    cohort_genome_builds = [
        "GTEx_v10": "hg38"
    ]
    liftover_chain_hg38_to_hg19 = "${projectDir}/reference_data/hg38ToHg19.over.chain.gz"

    min_present_cohorts = 2

    run_heterogeneity_summary = true
    run_plot_meta = true
    run_heterogeneity_breakdown = false
}
