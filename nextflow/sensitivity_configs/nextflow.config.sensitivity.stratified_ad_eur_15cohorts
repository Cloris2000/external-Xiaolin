/*
 * Ancestry-matched diagnosis stratum: AD cohorts, EUR-homogeneous only.
 *
 * Cohorts: ROSMAP, ROSMAP_array, Mayo, MSBB
 * Excludes: AMP-AD diverse (mixed ancestry), psychiatric, HBCC, controls
 *
 * Run: sbatch run_stratified_meta_ad_eur.sbatch
 */
includeConfig '../nextflow.config.standalone_meta_15cohorts'

params {
    stratified_meta_label = "AD_EUR"
    stratified_meta_dimension = "diagnosis_group_ancestry_matched"

    cohorts = [
        "ROSMAP", "ROSMAP_array", "Mayo", "MSBB"
    ]
    cohort_include = [
        "ROSMAP", "ROSMAP_array", "Mayo", "MSBB"
    ]

    output_dir = "${projectDir}/results/meta_sensitivity/stratified_ad_eur_15cohorts"
    harmonized_output_dir = "${params.output_dir}/harmonized"
    audit_output_dir = "${params.output_dir}/audit"
    heterogeneity_output_dir = "${params.output_dir}/heterogeneity"

    // Reuse harmonized cohort files from AD_neurological meta (6-cohort harmonization;
    // METAL here subsets to the 4 EUR AD cohorts only). No liftover needed.
    pre_harmonized_input_dir = "${projectDir}/results/meta_sensitivity/stratified_ad_neurological_15cohorts/harmonized"
    cohort_genome_builds = [:]
    liftover_chain_hg38_to_hg19 = null

    // Array workers run one cell type each; merge sbatch runs audit + heterogeneity summary.
    run_cohort_audit = false
    run_heterogeneity_summary = false
    run_plot_meta = false
    run_heterogeneity_breakdown = false
}
