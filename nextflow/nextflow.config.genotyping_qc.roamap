/*
 * ROSMAP Genotyping QC Configuration
 */

params {
    study = "ROSMAP"
    work_dir = '/external/rprshnas01/netdata_kcni/stlab/Xiaolin/WGS/QC/ROSMAP_joint_WGS_update_maf5'
    output_dir = "${work_dir}"
    
    // VCF files from joint analysis
    vcf_pattern = '"/external/rprshnas01/netdata_kcni/stlab/Xiaolin/WGS/ROSMAP_joint_WGS_vcf/NIA_JG_1898_samples_GRM_WGS_b37_JointAnalysis01_2017-12-08_{chrom}.recalibrated_variants.Broad_Rush.vcf.gz"'
    normalized_vcf_dir = '/external/rprshnas01/netdata_kcni/stlab/Xiaolin/WGS/ROSMAP_joint_WGS_vcf_normalized'
    normalize_vcf = true
    
    // Sample filtering
    samples_to_keep = '/nethome/kcni/xzhou/GWAS_tut/ROSMAP/ROSMAP_samples_with_phenotypes.txt'
    
    // QC thresholds
    maf_threshold = 0.05
    mach_r2_filter = 0.8
    
    // VCF quality filters
    vcf_min_gq = 20
    vcf_min_dp = 10
    vcf_min_qual = 30
    
    log_dir = '/external/rprshnas01/netdata_kcni/stlab/Xiaolin/WGS/QC/ROSMAP_joint_WGS_log'
}


