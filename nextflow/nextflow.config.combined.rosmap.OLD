/*
 * Combined Pipeline Configuration for ROSMAP Cohort
 * 
 * This configuration runs all three workflows in sequence:
 * 1. PHENOTYPE_PIPELINE: Process expression data
 * 2. GENOTYPING_QC_PIPELINE: QC genotyping data
 * 3. GWAS_PIPELINE: Perform GWAS analysis
 */

// Include base combined configuration
includeConfig 'nextflow.config.combined'

params {
    // ============================================================================
    // GENERAL PARAMETERS
    // ============================================================================
    
    cohorts = ["ROSMAP"]
    study = "ROSMAP"
    
    // Conda environment (optional)
    conda_env = "test"
    
    // ============================================================================
    // PHENOTYPE PIPELINE PARAMETERS
    // ============================================================================
    
    // Input files (from original ROSMAP phenotype config)
    count_matrix_file = '/external/rprshnas01/netdata_kcni/stlab/Xiaolin/metabrain_PCA/data/ROSMAP_DLPFC_batch_all.csv'
    metadata_file = '/external/rprshnas01/netdata_kcni/stlab/Xiaolin/metabrain_PCA/data/ROSMAP_combined_metrics.csv'
    
    // WGS files - these will be generated by GENOTYPING_QC_PIPELINE
    wgs_psam_file = "${projectDir}/results/ROSMAP/ROSMAP.QC.final.psam"
    pca_file = "${projectDir}/results/ROSMAP/pca.csv"
    
    // Optional files - ROSMAP has biospecimen file
    biospecimen_file = '/nethome/kcni/xzhou/GWAS_tut/AMP-AD/ROSMAP_biospecimen_metadata.csv'
    
    // Processing parameters (from original config)
    tissue_filter = 'dorsolateral prefrontal cortex'
    col_sample_id_for_matching = ''  // Auto-detect (will use synapseID/id for ROSMAP)
    top_n_tech_cov = 20  // FIXED: was 10, original is 20
    min_gene_variance = 0.1  // ADDED: missing from combined config
    
    // Cell type deconvolution
    deconv_tool = "MGP"
    reference_taxonomy = 'sonny_markers'  // Options: 'sonny_markers', 'aging_paper', 'custom'
    marker_file = '/external/rprshnas01/netdata_kcni/stlab/Xiaolin/metabrain_PCA/data/new_MTGnCgG_lfct2.5_Publication.csv'
    hgnc_mapping_file = '/external/rprshnas01/kcni/dkiss/cell_prop_psychiatry/data/hgnc_complete_set.txt'  // FIXED: from original config
    
    // Phenotype/covariate preparation (from original config)
    fid_method = 'study_projid'  // FIXED: was 'match', original is 'study_projid'
    fid_format = ''  // FIXED: was 'specimenID', original is empty string
    col_msex = "msex"
    biospec_col_individual = "individualID"
    biospec_col_specimen = "specimenID"
    
    // ============================================================================
    // GENOTYPING QC PIPELINE PARAMETERS
    // ============================================================================
    
    // Input VCF files - ROSMAP uses WGS data (from original config)
    vcf_dir = ""  // Not used when vcf_pattern has full path
    vcf_pattern = '"/external/rprshnas01/netdata_kcni/stlab/Xiaolin/WGS/ROSMAP_joint_WGS_vcf/NIA_JG_1898_samples_GRM_WGS_b37_JointAnalysis01_2017-12-08_{chrom}.recalibrated_variants.Broad_Rush.vcf.gz"'
    normalized_vcf_dir = "/external/rprshnas01/netdata_kcni/stlab/Xiaolin/WGS/ROSMAP_joint_WGS_vcf_normalized"
    
    // Software paths
    plink_path = "/external/rprshnas01/kcni/mwainberg/software/plink2"
    bcftools_path = "/nethome/kcni/xzhou/.anaconda3/envs/bcftools_env/bin/bcftools"
    
    // QC parameters (from original config)
    maf_threshold = 0.05
    hwe_threshold = 1e-6
    geno_threshold = 0.1
    mind_threshold = 0.1
    
    // VCF filtering - ROSMAP is WGS data, so we can filter on quality
    vcf_min_gq = 20      // Minimum genotype quality
    vcf_min_dp = 10      // Minimum read depth
    vcf_min_qual = 30    // Minimum variant quality
    mach_r2_filter = 0.8  // From original config
    
    // LD pruning
    prune_window_size = 1000
    prune_step_size = 50
    prune_r2_threshold = 0.2
    
    // Processing options
    normalize_vcf = true   // ROSMAP VCFs need normalization
    include_x = false
    sort_vars = true
    autosome_only = true
    samples_to_keep = "${projectDir}/results/ROSMAP/samples_to_keep.txt"   // Leave empty to keep all samples
    
    // Directories
    work_dir = "${projectDir}/work/ROSMAP"
    log_dir = "${projectDir}/logs/ROSMAP"
    output_dir = "${projectDir}/results/ROSMAP"
    
    // SLURM (from original config - ROSMAP uses SLURM for VCF normalization)
    use_slurm = true
    slurm_time = "0-4:0"
    
    // ============================================================================
    // GWAS PIPELINE PARAMETERS
    // ============================================================================
    
    // Software paths
    regenie_path = "/external/rprshnas01/kcni/mwainberg/software/regenie"
    metal_path = "/external/rprshnas01/netdata_kcni/stlab/Xiaolin/WGS/METAL/generic-metal/executables"
    
    // Regenie parameters
    regenie_threads = 12  // Reduced to match available CPUs
    regenie_bsize = 1000
    
    // ============================================================================
    // COHORT-SPECIFIC CONFIGURATIONS
    // ============================================================================
    
    // These paths reference the outputs from PHENOTYPE_PIPELINE and GENOTYPING_QC_PIPELINE
    cohort_configs = [
        "ROSMAP": [
            pgen_file: "${projectDir}/results/ROSMAP/ROSMAP.QC.final",
            prune_in_file: "${projectDir}/results/ROSMAP/ROSMAP.QC.prune.in",
            pheno_file: "${projectDir}/results/ROSMAP/phenotypes_RINT.txt",
            covar_file: "${projectDir}/results/ROSMAP/covariates.txt"
        ]
    ]
}

// Process configuration - adjust to available resources
process {
    // Reduce CPU requirements to match available resources (12 CPUs)
    withName: 'COMBINED_PIPELINE:GENOTYPING_QC_PIPELINE:.*' {
        cpus = { task.attempt == 1 ? 8 : 4 }
        memory = '32 GB'
    }
    
    withName: 'COMBINED_PIPELINE:PHENOTYPE_PIPELINE:.*' {
        cpus = { task.attempt == 1 ? 4 : 2 }
        memory = '16 GB'
    }
    
    withName: 'COMBINED_PIPELINE:GWAS_PIPELINE:REGENIE_STEP1' {
        cpus = 12  // Use all available CPUs
        memory = '48 GB'
    }
    
    withName: 'COMBINED_PIPELINE:GWAS_PIPELINE:REGENIE_STEP2' {
        cpus = 12  // Use all available CPUs
        memory = '48 GB'
    }
    
    withName: 'COMBINED_PIPELINE:GWAS_PIPELINE:EXTRACT_PHENOTYPE_COLUMN' {
        cpus = 1
        memory = '4 GB'
    }
    
    withName: 'COMBINED_PIPELINE:CHECK_GENOTYPING_COMPLETE' {
        cpus = 1
        memory = '1 GB'
    }
}

